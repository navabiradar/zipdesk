# Server
APP_ENV=development
APP_PORT=8080
APP_SECRET=your-256-bit-secret-here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zipdesk?sslmode=disable
DATABASE_MAX_CONNECTIONS=20

# Redis
REDIS_URL=redis://default:pass@host:6379

# ClickHouse
CLICKHOUSE_DSN=clickhouse://user:pass@host:9000/zipdesk

# Storage
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=zipdesk-files
CLOUDFLARE_R2_PUBLIC_URL=https://files.zipdesk.io

# Email
RESEND_API_KEY=re_
EMAIL_FROM=hello@zipdesk.io
EMAIL_FROM_NAME=ZipDesk

# AWS SES
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=

# Auth
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=720h

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# AI
ANTHROPIC_API_KEY=sk-ant-

# GeoIP
MAXMIND_DB_PATH=./data/GeoLite2-City.mmdb

# Asynq
ASYNQ_REDIS_URL=redis://default:pass@host:6379

# App URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8080
